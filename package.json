{
  "name": "@validkit/mcp-server",
  "version": "1.1.1",
  "description": "Model Context Protocol (MCP) server for ValidKit email validation - works with Claude Code, Cursor, Windsurf, and any MCP-compatible AI assistant",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build"
  },
  "bin": {
    "validkit-mcp": "dist/index.js"
  },
  "keywords": [
    "mcp",
    "email-validation",
    "validkit",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf",
    "ai-tools"
  ],
  "author": "ValidKit",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ValidKit/validkit-mcp-server.git"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
