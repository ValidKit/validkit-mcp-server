{
  "claude_desktop": {
    "comment": "Add this to ~/Library/Application Support/Claude/claude_desktop_config.json on Mac",
    "mcpServers": {
      "validkit": {
        "command": "npx",
        "args": ["-y", "@validkit/mcp-server"],
        "env": {
          "VALIDKIT_API_KEY": "your_validkit_api_key_here"
        }
      }
    }
  },
  "other_mcp_clients": {
    "comment": "Example configuration for other MCP clients",
    "server": {
      "command": "npx -y @validkit/mcp-server",
      "transport": "stdio",
      "env": {
        "VALIDKIT_API_KEY": "your_validkit_api_key_here"
      }
    }
  }
}